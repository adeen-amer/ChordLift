# Comma-separated origins allowed for CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Server port (default 8000)
PORT=8000

# Optional: path to a Netscape-format cookies.txt for YouTube (export from browser)
# YTDLP_COOKIES_FILE=/path/to/cookies.txt

# Optional: comma-separated fallback proxy APIs if yt-dlp fails
# PIPED_INSTANCES=https://pipedapi.kavin.rocks
# INVIDIOUS_INSTANCES=https://inv.nadeko.net

# Chord engine: ml (default, autochord + classic chroma re-score) or classic
# CHORD_ENGINE=ml

# Pitch-correct detuned audio (±1 semitone) before chord analysis; set 0 to disable
# CHORD_PITCH_CORRECT=1

# Cached analyses invalidate automatically when ANALYZER_VERSION or CHORD_ENGINE changes.
# Re-analyze to refresh lyrics on older cached results.
