# Chord engine: ml (default) or classic
# CHORD_ENGINE=ml
# CHORD_MODEL=chordia
# CHORD_ML_MODEL=chordia  # alias for CHORD_MODEL; ensemble → chordia (deprecated)

# Spotify API (recommended for local gold bootstrap + production metadata)
# SPOTIFY_CLIENT_ID=
# SPOTIFY_CLIENT_SECRET=

# CHORD_CHORDIA_DICT=submission   # submission | ismir2017

# Chord AI-style prep: stem separation before harmony analysis
# CHORD_STEM_MODE=auto   # auto | hpss | demucs | best

# Pitch-correct detuned audio (±1 semitone, reliability-gated); set 0 to disable
# CHORD_PITCH_CORRECT=1

# Cached analyses invalidate automatically when ANALYZER_VERSION or CHORD_ENGINE changes.
